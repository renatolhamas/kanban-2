{
  "permissions": {
    "allow": [
      "Bash(git --version)",
      "Bash(gh --version)",
      "Bash(npm --version)",
      "Bash(docker --version)",
      "Bash(supabase --version)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(gh repo:*)",
      "Bash([ -d .git ])",
      "Bash([ -f .gitignore ])",
      "Bash([ -f .aiox/environment-report.yaml ])",
      "Bash(gh auth:*)",
      "Bash(git push:*)"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "supabase"
  ],
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"C:\\\\git\\\\rent\\\\.claude\\\\hooks\\\\code-intel-pretool.cjs\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"C:\\\\git\\\\rent\\\\.claude\\\\hooks\\\\precompact-session-digest.cjs\"",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"C:\\\\git\\\\rent\\\\.claude\\\\hooks\\\\synapse-engine.cjs\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
